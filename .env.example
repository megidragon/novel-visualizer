# AI Provider: claude-cli | claude-api | openrouter | lmstudio
AI_PROVIDER=claude-cli

# Model name (format depends on provider)
# claude-cli:  ignored (uses whatever model Claude Code is configured with)
# claude-api:  claude-opus-4-6, claude-sonnet-4-6, etc.
# openrouter:  anthropic/claude-opus-4, meta-llama/llama-3-70b, etc.
# lmstudio:    loaded model name from LM Studio
AI_MODEL=claude-opus-4-6

# Claude API (only needed if AI_PROVIDER=claude-api)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (only needed if AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...

# LM Studio (only needed if AI_PROVIDER=lmstudio)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234

# Max tokens for AI response (default: 16384)
AI_MAX_TOKENS=16384

PORT=3001

# Piper TTS (download from https://github.com/rhasspy/piper/releases)
PIPER_EXECUTABLE_PATH=C:/path/to/piper.exe
PIPER_MODEL_PATH=C:/path/to/model.onnx

# FFmpeg (install via winget install ffmpeg)
FFMPEG_PATH=ffmpeg
